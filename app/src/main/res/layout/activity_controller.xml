<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Remote screen display -->
    <SurfaceView
        android:id="@+id/mirror_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Status overlay -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="#80000000"
        android:text="@string/connecting" />

    <!-- Control buttons at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:background="#80000000">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_back" />

        <ImageButton
            android:id="@+id/btn_home"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_menu_compass"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_home" />

        <ImageButton
            android:id="@+id/btn_recents"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_menu_recent_history"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_recents" />

        <ImageButton
            android:id="@+id/btn_power"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_power" />

        <ImageButton
            android:id="@+id/btn_unlock"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_lock_lock"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_unlock"
            android:tooltipText="@string/btn_unlock_hint" />
    </LinearLayout>

</FrameLayout>
