<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- Role selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_role"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/role_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radio_controller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/role_controller"
                android:checked="true"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/radio_relay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/role_relay"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/radio_controlled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/role_controlled"
                android:padding="8dp" />
        </RadioGroup>

        <!-- Transport selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_transport"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/transport_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radio_bluetooth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/transport_bluetooth"
                android:checked="true"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/radio_usb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/transport_usb"
                android:padding="8dp" />
        </RadioGroup>

        <!-- Start button (launches role-specific activity + screen mirror) -->
        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/start"
            android:textSize="18sp" />

        <!-- Permission status panel (hidden when all permissions granted) -->
        <LinearLayout
            android:id="@+id/permission_status_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_permission_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/permission_panel_title"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_permission_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_permission_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/permission_details"
                style="?android:attr/buttonBarButtonStyle"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginVertical="24dp" />

        <!-- Additional features (work independently of screen mirroring) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feature_screen_mirror"
            android:textSize="14sp"
            android:textStyle="italic"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_clipboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feature_clipboard"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_file_transfer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feature_file_transfer"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_folder_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feature_folder_sync"
            android:layout_marginBottom="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginVertical="12dp" />

        <Button
            android:id="@+id/btn_shortcut_config"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shortcut_config_title"
            android:layout_marginBottom="8dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tv_connection_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="13sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
