<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:minWidth="300dp">

    <!-- Share icon -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_share"
        android:contentDescription="@string/share_to_remote" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/share_confirm_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <!-- Content preview -->
    <TextView
        android:id="@+id/tv_share_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:maxLines="5"
        android:ellipsize="end"
        android:background="@android:drawable/editbox_background"
        android:padding="8dp" />

    <!-- Confirm message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/share_confirm_message"
        android:layout_marginTop="12dp"
        android:textSize="14sp" />

    <!-- Status -->
    <ProgressBar
        android:id="@+id/progress_share"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:indeterminate="true" />

    <TextView
        android:id="@+id/tv_share_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="end">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_cancel"
            style="?android:attr/buttonBarNegativeButtonStyle" />

        <Button
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_send"
            style="?android:attr/buttonBarPositiveButtonStyle"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
